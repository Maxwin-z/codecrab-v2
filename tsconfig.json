    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/channels" },
    { "path": "packages/server" },
    { "path": "packages/app" },
    { "path": "packages/web" },
    { "path": "packages/relay" },
    { "path": "packages/cli" }
  ]
}
