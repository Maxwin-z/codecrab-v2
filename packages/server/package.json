{
  "name": "@codecrab/server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "CodeCrab server — four-layer architecture (Gateway/Core/Agent/Soul+Cron)",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/start.ts",
    "./auth": "./src/gateway/auth.ts"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --signal SIGTERM --exec 'tsx src/index.ts'",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@codecrab/shared": "workspace:*",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
